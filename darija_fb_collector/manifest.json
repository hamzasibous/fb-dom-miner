{
  "manifest_version": 3,
  "name": "FB Auto-Archive",
  "version": "1.2",
  "permissions": ["storage", "unlimitedStorage", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}